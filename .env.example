# Copia este archivo a ".env" en la MISMA carpeta del proyecto (ECOMMERCE2).

# ── Misma TIENDA en las dos siguientes líneas (obligatorio si no es Nexorien-2):

# Tu dominio myshopify: Admin → Ajustes → Información · dominio de la tienda (sin https)
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com

SHOPIFY_STOREFRONT_ACCESS_TOKEN=paste_storefront_public_token_here

# Opcional:
# SHOPIFY_STOREFRONT_API_VERSION=2026-04
